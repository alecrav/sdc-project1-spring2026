    br2 [label="br2\n@0 (lat=0)"];
    br3 [label="br3\n@0 (lat=0)"];
    {rank=same; br1; br2; br3;}
    {rank=max; dot_1 [shape=point, width=0.08, color=blue]; dot_3 [shape=point, width=0.08, color=blue]; dot_5 [shape=point, width=0.08, color=blue];}

  }

  start0 -> constant2 [color=purple];
  start0 -> constant3 [color=purple];
  constant2 -> br1;
  constant3 -> br2;
  start0 -> br3 [color=purple];

