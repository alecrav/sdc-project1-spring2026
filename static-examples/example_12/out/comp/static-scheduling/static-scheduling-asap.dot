    {rank=same; dot_10 [shape=point, width=0.08, color=blue]; dot_13 [shape=point, width=0.08, color=blue]; dot_16 [shape=point, width=0.08, color=blue];}
    dot_0 -> dot_10 [style=invis, minlen=2];
    {rank=same; phi0; phi1; phi2;}
    dot_10 -> phi0 [style=invis, minlen=2];
    {rank=same; cond_br4; cond_br5;}
    {rank=same; cond_br1; cond_br2; cond_br3;}
    cond_br5 -> cond_br3 [style=invis];
