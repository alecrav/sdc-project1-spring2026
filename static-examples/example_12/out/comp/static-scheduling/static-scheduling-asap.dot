    {rank=same; dot_11 [shape=point, width=0.08, color=blue]; dot_14 [shape=point, width=0.08, color=blue]; dot_17 [shape=point, width=0.08, color=blue];}
    {rank=max; dot_7 [shape=point, width=0.08, color=blue]; dot_9 [shape=point, width=0.08, color=blue];}
    dot_11 -> dot_7 [style=invis, minlen=2];

  }

  phi2 -> constant4 [color=purple];
